TELEMT_URL=http://127.0.0.1:9091
TELEMT_AUTH=your-auth-header-value
BOT_TOKEN=123456:ABC-your-bot-token
ALLOWED_USERNAMES=alice,bob
# Only show proxy links for this public IP/hostname. Leave empty to show all.
LINK_HOST=1.2.3.4
# Optional proxy for Telegram API connections. Supports HTTP and SOCKS5.
# Examples:
#   PROXY_URL=http://host:port
#   PROXY_URL=http://user:pass@host:port
#   PROXY_URL=socks5://host:port
#   PROXY_URL=socks5://user:pass@host:port
PROXY_URL=
LOG_LEVEL=INFO
